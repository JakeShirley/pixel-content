---
interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Browse and download animation content for Pixel Wall displays.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#f7f6f3" />
    <title>{title}</title>
    <style is:global>
      :root {
        color-scheme: light;
        --ink: #343330;
        --muted: #85817a;
        --line: #dedbd5;
        --panel: #ffffff;
        --page: #f7f6f3;
        --accent: #b48737;
        --accent-strong: #85621f;
        --surface-muted: #eeece7;
        --backdrop: rgba(28, 27, 25, 0.72);
        --font-body: Georgia, "Times New Roman", serif;
        --font-ui: "Trebuchet MS", "Segoe UI", sans-serif;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        color: var(--ink);
        background: var(--page);
        font-family: var(--font-body);
        line-height: 1.45;
      }

      header,
      main,
      footer {
        width: min(1600px, calc(100% - 40px));
        margin: 0 auto;
      }

      header {
        padding: 0;
      }

      h1,
      h2,
      h3,
      p {
        margin: 0;
      }

      h1 {
        font-size: 1.15rem;
        line-height: 1;
        letter-spacing: 0;
      }

      main {
        padding: 36px 0 72px;
      }

      ol {
        columns: 5 240px;
        column-gap: 6px;
        list-style: none;
        margin: 0;
        padding: 0;
      }

      footer {
        padding: 20px 0 36px;
        border-top: 1px solid var(--line);
        color: var(--muted);
        font: 0.75rem/1.4 var(--font-ui);
      }

      @media (max-width: 600px) {
        header,
        main,
        footer {
          width: min(100% - 20px, 1600px);
        }

        ol {
          columns: 2 150px;
          column-gap: 4px;
        }
      }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
