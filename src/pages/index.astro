---
import Layout from '../layouts/Layout.astro';
import AnimationCard from '../components/AnimationCard.astro';
import { collectAnimationMetadata } from '../utils/collectAnimations';

const content = await collectAnimationMetadata('./assets/processed');
const animationsByName = new Map(
  content.animations.map((anim) => [anim.publishedName, anim])
);

function chip(text: string) {
  return text;
}
---

<Layout title="Pixel Wall Animation Content">
  <header>
    <h1>Pixel Wall Animation Content</h1>
    <div class="summary">
      <span>{chip(`${content.animations.length} animation${content.animations.length === 1 ? '' : 's'}`)}</span>
      <span>{chip(`${Object.keys(content.buckets).length} manifest${Object.keys(content.buckets).length === 1 ? '' : 's'}`)}</span>
    </div>
    <div class="tools-links">
      <a href="converter/">Animation Converter Tool</a>
    </div>
  </header>
  
  <main id="manifests">
    {Object.entries(content.buckets).map(([dimensions, names]) => (
      <section>
        <div class="manifest-title">
          <h2>{dimensions}</h2>
          <a href={`manifest/${dimensions}`}>manifest/{dimensions}</a>
          <span>{chip(`${names.length} item${names.length === 1 ? '' : 's'}`)}</span>
        </div>
        <ol start={0}>
          {names.map((publishedName, imageIndex) => {
            const animation = animationsByName.get(publishedName);
            return animation ? (
              <AnimationCard animation={animation} imageIndex={imageIndex} />
            ) : null;
          })}
        </ol>
      </section>
    ))}
  </main>
  
  <footer>
    <p>Preview rendered from deployed .bin bytes.</p>
  </footer>

  <script>
    // Animation preview rendering
    function decodeAnimationBinary(bytes: Uint8Array, width: number, height: number) {
      if (bytes.length < 10) {
        throw new Error("file is smaller than the header");
      }

      const view = new DataView(bytes.buffer, bytes.byteOffset, bytes.byteLength);
      const fps = view.getUint8(3);
      const paletteBytes = view.getUint16(4, true);
      const frameBytes = view.getUint32(6, true);
      const totalPixels = width * height;
      const palette: [number, number, number][] = [];
      let offset = 10;
      
      for (let index = 0; index < paletteBytes; index += 3) {
        palette.push([
          bytes[offset + index],
          bytes[offset + index + 1],
          bytes[offset + index + 2],
        ]);
      }

      offset += paletteBytes;
      const frameEnd = offset + frameBytes;
      const frames: Uint8Array[] = [];
      let current: Uint8Array | null = null;
      
      function readU16BE(bytes: Uint8Array, offset: number) {
        return (bytes[offset] << 8) | bytes[offset + 1];
      }

      while (offset < frameEnd) {
        const record = bytes[offset];
        offset += 1;
        
        if (record === 0x49) {
          const pixelCount = readU16BE(bytes, offset);
          offset += 2;
          current = new Uint8Array(totalPixels);
          current.set(bytes.subarray(offset, offset + pixelCount), 0);
          offset += pixelCount;
          frames.push(current.slice());
        } else if (record === 0x50) {
          if (!current) {
            throw new Error("predictive frame before keyframe");
          }
          const changedPixels = readU16BE(bytes, offset);
          offset += 2;
          const positionBytes = totalPixels > 256 ? 2 : 1;
          const next = current.slice();
          for (let index = 0; index < changedPixels; index += 1) {
            const position = positionBytes === 2 ? readU16BE(bytes, offset) : bytes[offset];
            offset += positionBytes;
            next[position] = bytes[offset];
            offset += 1;
          }
          current = next;
          frames.push(current.slice());
        }
      }

      return { frames, palette, fps };
    }

    function drawFrame(
      ctx: CanvasRenderingContext2D,
      decoded: any,
      frameIndex: number
    ) {
      const frame = decoded.frames[frameIndex];
      const palette = decoded.palette;
      const imageData = ctx.createImageData(ctx.canvas.width, ctx.canvas.height);
      const data = imageData.data;

      for (let i = 0; i < frame.length; i++) {
        const paletteIndex = frame[i];
        const [r, g, b] = palette[paletteIndex];
        data[i * 4] = r;
        data[i * 4 + 1] = g;
        data[i * 4 + 2] = b;
        data[i * 4 + 3] = 255;
      }

      ctx.putImageData(imageData, 0, 0);
    }

    async function renderAnimationPreview(
      animationPath: string,
      canvas: HTMLCanvasElement,
      status: HTMLElement
    ) {
      try {
        const response = await fetch(animationPath);
        if (!response.ok) {
          throw new Error(`HTTP ${response.status}`);
        }

        const decoded = decodeAnimationBinary(
          new Uint8Array(await response.arrayBuffer()),
          canvas.width,
          canvas.height
        );
        
        const context = canvas.getContext("2d");
        if (!context) throw new Error("Could not get canvas context");
        
        const delay = Math.max(20, Math.round(1000 / Math.max(1, decoded.fps)));
        let frame = 0;
        drawFrame(context, decoded, frame);
        status.textContent = "";
        status.hidden = true;

        if (decoded.frames.length > 1) {
          setInterval(() => {
            frame = (frame + 1) % decoded.frames.length;
            drawFrame(context, decoded, frame);
          }, delay);
        }
      } catch (error) {
        status.hidden = false;
        status.textContent = `Preview unavailable: ${error instanceof Error ? error.message : String(error)}`;
      }
    }

    // Initialize all animation previews
    document.querySelectorAll("[data-animation-preview]").forEach((canvas) => {
      const canvasEl = canvas as HTMLCanvasElement;
      const animationPath = canvasEl.getAttribute("data-animation-preview");
      const statusEl = canvasEl.nextElementSibling as HTMLElement;
      
      if (animationPath) {
        renderAnimationPreview(animationPath, canvasEl, statusEl);
      }
    });
  </script>
</Layout>
