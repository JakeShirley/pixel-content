---
import Layout from '../layouts/Layout.astro';
import AnimationCard from '../components/AnimationCard.astro';
import { collectAnimationMetadata } from '../utils/collectAnimations';

const content = await collectAnimationMetadata('./assets/processed');
const buckets = content.buckets as Record<string, string[]>;
const animationsByName = new Map(
  content.animations.map((anim) => [anim.publishedName, anim])
);
const onDisplayCounts: Record<string, number> = {
  '128x128': 2,
  '32x32': 3,
  '128x64': 5,
  '32x64': 4,
  '64x32': 1,
  '64x64': 4,
};
const dimensions = Object.keys(buckets);
const orderedAnimations = dimensions.flatMap((dimension) =>
  buckets[dimension]
    .map((publishedName, deployedIndex) => {
      const animation = animationsByName.get(publishedName);
      return animation ? { ...animation, deployedIndex } : undefined;
    })
    .filter((animation) => animation !== undefined)
).map((animation, galleryOrder) => ({
  ...animation,
  galleryOrder,
  displayState: animation.deployedIndex < (onDisplayCounts[animation.dimensions] ?? 0)
    ? 'on-display'
    : 'coming-soon',
}));
const onDisplayAnimations = orderedAnimations.filter((animation) => animation.displayState === 'on-display');
const comingSoonAnimations = orderedAnimations.filter((animation) => animation.displayState === 'coming-soon');
const basePath = `${import.meta.env.BASE_URL.replace(/\/$/, '')}/`;
---

<Layout title="Pixel Wall Animation Content">
  <header class="site-header">
    <div class="header-inner">
      <a class="identity" href="#gallery" aria-label="Pixel Wall animation gallery">
        <span class="pixel-mark" aria-hidden="true"><i></i><i></i><i></i><i></i><i></i></span>
        <span><h1>Pixel Wall</h1><small>Animation Gallery</small></span>
      </a>
      <nav aria-label="Filter animations by display size">
        <button type="button" data-gallery-filter="all" aria-pressed="true">All</button>
        {dimensions.map((dimension) => (
          <button type="button" data-gallery-filter={dimension} aria-pressed="false">{dimension}</button>
        ))}
      </nav>
      <a class="editor-link" href={`${basePath}converter/`}>Animation Editor</a>
    </div>
  </header>

  <div class="collection-bar">
    <p><strong data-gallery-count>{content.animations.length}</strong> gallery animations</p>
    <div class="manifest-links" aria-label="Animation manifests">
      <span>Manifests</span>
      {dimensions.map((dimension) => (
        <button type="button" data-manifest-open={`manifest-${dimension}`}>{dimension}</button>
      ))}
    </div>
  </div>

  {Object.entries(buckets).map(([dimension, names]) => (
    <dialog id={`manifest-${dimension}`} class="manifest-dialog">
          <div class="dialog-heading">
            <h3>manifest/{dimension}</h3>
            <button type="button" class="dialog-close" data-manifest-close aria-label="Close manifest" title="Close">
              &times;
            </button>
          </div>
          <pre>{names.join('\n')}</pre>
          <a href={`manifest/${dimension}`}>Download manifest file</a>
        </dialog>
  ))}

  <main id="gallery">
    <section class="gallery-section" data-gallery-section="on-display">
      <div class="section-heading">
        <div>
          <p>Currently deployed</p>
          <h2>On Display</h2>
        </div>
        <span data-section-count="on-display">{onDisplayAnimations.length}</span>
      </div>
      <ol data-gallery-list="on-display">
        {onDisplayAnimations.map((animation) => (
          <AnimationCard
            animation={animation}
            galleryOrder={animation.galleryOrder}
            displayState={animation.displayState}
          />
      ))}
      </ol>
    </section>

    <section class="gallery-section" data-gallery-section="coming-soon">
      <div class="section-heading">
        <div>
          <p>Queued for deployment - Images are rotated in daily via GitHub Actions</p>
          <h2>Coming Soon</h2>
        </div>
        <span data-section-count="coming-soon">{comingSoonAnimations.length}</span>
      </div>
      <ol data-gallery-list="coming-soon">
        {comingSoonAnimations.map((animation) => (
          <AnimationCard
            animation={animation}
            galleryOrder={animation.galleryOrder}
            displayState={animation.displayState}
          />
        ))}
      </ol>
    </section>
  </main>
  
  <footer>
    <p>Preview rendered from deployed .bin bytes.</p>
  </footer>

  <style>
    .site-header {
      position: sticky;
      z-index: 10;
      top: 0;
      width: 100%;
      border-bottom: 1px solid var(--line);
      background: rgba(247, 246, 243, 0.96);
      backdrop-filter: blur(12px);
    }

    .header-inner {
      display: grid;
      grid-template-columns: auto 1fr auto;
      align-items: center;
      gap: 32px;
      width: min(1600px, calc(100% - 40px));
      min-height: 70px;
      margin: 0 auto;
    }

    .identity {
      display: flex;
      align-items: center;
      gap: 12px;
      color: var(--ink);
      text-decoration: none;
    }

    .identity small {
      display: block;
      margin-top: 4px;
      color: var(--muted);
      font: 0.68rem/1 var(--font-ui);
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .pixel-mark {
      display: grid;
      grid-template-columns: repeat(3, 8px);
      grid-template-rows: repeat(3, 8px);
      gap: 2px;
      width: 28px;
      height: 28px;
    }

    .pixel-mark i {
      background: var(--accent);
    }

    .pixel-mark i:nth-child(1) { grid-column: 2; }
    .pixel-mark i:nth-child(2) { grid-column: 1; grid-row: 2; }
    .pixel-mark i:nth-child(3) { grid-column: 2; grid-row: 2; }
    .pixel-mark i:nth-child(4) { grid-column: 3; grid-row: 2; }
    .pixel-mark i:nth-child(5) { grid-column: 2; grid-row: 3; }

    nav {
      display: flex;
      align-items: center;
      justify-self: end;
      gap: 22px;
      overflow-x: auto;
      scrollbar-width: none;
      font: 0.8rem/1 var(--font-ui);
      white-space: nowrap;
    }

    nav::-webkit-scrollbar {
      display: none;
    }

    nav button,
    .manifest-links button {
      border: 0;
      background: none;
      padding: 6px 0;
      color: var(--muted);
      cursor: pointer;
      font: inherit;
      text-decoration: none;
    }

    nav button:hover,
    nav button[aria-pressed="true"] {
      color: var(--ink);
    }

    nav button[aria-pressed="true"] {
      box-shadow: inset 0 -1px var(--accent);
    }

    .editor-link {
      padding: 8px 11px;
      border: 1px solid var(--line);
      border-radius: 2px;
      color: var(--ink);
      font: 0.76rem/1 var(--font-ui);
      text-decoration: none;
      white-space: nowrap;
    }

    .editor-link:hover {
      border-color: var(--accent);
      color: var(--accent-strong);
    }

    .collection-bar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 24px;
      width: min(1600px, calc(100% - 40px));
      margin: 0 auto;
      padding: 24px 0 0;
      color: var(--muted);
      font: 0.75rem/1.4 var(--font-ui);
    }

    .manifest-links {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: flex-end;
      gap: 12px;
    }

    .manifest-links span {
      color: var(--ink);
    }

    .manifest-links button:hover {
      color: var(--accent-strong);
    }

    #gallery {
      display: grid;
      gap: 64px;
    }

    .gallery-section {
      display: grid;
      gap: 20px;
    }

    .section-heading {
      display: flex;
      align-items: end;
      justify-content: space-between;
      gap: 20px;
      padding-bottom: 12px;
      border-bottom: 1px solid var(--line);
    }

    .section-heading p {
      margin-bottom: 4px;
      color: var(--muted);
      font: 0.68rem/1.2 var(--font-ui);
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }

    .section-heading h2 {
      font-size: clamp(1.7rem, 3vw, 2.5rem);
      font-weight: 400;
      line-height: 1;
    }

    .section-heading > span {
      display: grid;
      min-width: 34px;
      height: 34px;
      place-items: center;
      border: 1px solid var(--line);
      border-radius: 50%;
      color: var(--muted);
      font: 0.72rem/1 var(--font-ui);
    }

    .manifest-dialog {
      width: min(560px, calc(100% - 32px));
      max-height: min(720px, calc(100% - 32px));
      border: 1px solid var(--line);
      border-radius: 2px;
      background: var(--panel);
      padding: 20px;
      color: var(--ink);
      box-shadow: 0 20px 60px rgba(28, 27, 25, 0.18);
    }

    .manifest-dialog::backdrop {
      background: var(--backdrop);
    }

    .dialog-heading {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      margin-bottom: 16px;
    }

    .dialog-heading h3 {
      overflow-wrap: anywhere;
      font-size: 1.15rem;
    }

    .dialog-close {
      display: grid;
      flex: 0 0 36px;
      width: 36px;
      height: 36px;
      place-items: center;
      border: 1px solid var(--line);
      border-radius: 2px;
      background: var(--surface-muted);
      color: var(--ink);
      cursor: pointer;
      font: inherit;
      font-size: 1.5rem;
      line-height: 1;
    }

    .dialog-close:hover {
      background: var(--panel);
    }

    .manifest-dialog pre {
      max-height: 55vh;
      overflow: auto;
      margin: 0 0 16px;
      border: 1px solid var(--line);
      border-radius: 2px;
      background: var(--surface-muted);
      padding: 14px;
      font-size: 0.9rem;
      line-height: 1.65;
      white-space: pre-wrap;
      overflow-wrap: anywhere;
    }

    .manifest-dialog > a {
      color: var(--accent-strong);
      font-weight: 700;
      text-decoration: none;
    }

    .manifest-dialog > a:hover {
      text-decoration: underline;
    }

    @media (max-width: 760px) {
      .header-inner {
        grid-template-columns: 1fr auto;
        gap: 10px;
        width: min(100% - 20px, 1600px);
        padding: 12px 0;
      }

      nav {
        grid-column: 1 / -1;
        grid-row: 2;
        justify-self: stretch;
        gap: 18px;
        padding-bottom: 2px;
      }

      .editor-link {
        grid-column: 2;
        grid-row: 1;
      }

      .collection-bar {
        display: grid;
        width: min(100% - 20px, 1600px);
        padding-top: 18px;
      }

      .manifest-links {
        justify-content: flex-start;
      }
    }
  </style>

  <script>
    const filterButtons = document.querySelectorAll("[data-gallery-filter]");
    const galleryItems = document.querySelectorAll("[data-animation-dimensions]");
    const galleryLists = document.querySelectorAll("[data-gallery-list]");
    const galleryCount = document.querySelector("[data-gallery-count]");

    filterButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const filter = (button as HTMLElement).dataset.galleryFilter;
        let visibleCount = 0;

        galleryItems.forEach((item) => {
          const matches = filter === "all" || (item as HTMLElement).dataset.animationDimensions === filter;
          (item as HTMLElement).hidden = !matches;
          if (matches) visibleCount += 1;
        });

        const orderAttribute = filter === "all" ? "galleryOrder" : "deployedIndex";
        galleryLists.forEach((list) => {
          const displayState = (list as HTMLElement).dataset.galleryList;
          const sectionItems = [...galleryItems]
            .filter((item) => (item as HTMLElement).dataset.displayState === displayState)
            .sort((left, right) => {
              const leftOrder = Number((left as HTMLElement).dataset[orderAttribute]);
              const rightOrder = Number((right as HTMLElement).dataset[orderAttribute]);
              return leftOrder - rightOrder;
            });

          sectionItems.forEach((item) => list.append(item));

          const sectionCount = document.querySelector(`[data-section-count="${displayState}"]`);
          if (sectionCount) {
            sectionCount.textContent = String(sectionItems.filter((item) => !(item as HTMLElement).hidden).length);
          }
        });

        filterButtons.forEach((candidate) => {
          candidate.setAttribute("aria-pressed", String(candidate === button));
        });

        if (galleryCount) galleryCount.textContent = String(visibleCount);
      });
    });

    // Animation preview rendering
    function decodeAnimationBinary(bytes: Uint8Array, width: number, height: number) {
      if (bytes.length < 10) {
        throw new Error("file is smaller than the header");
      }

      const view = new DataView(bytes.buffer, bytes.byteOffset, bytes.byteLength);
      const fps = view.getUint8(3);
      const paletteBytes = view.getUint16(4, true);
      const frameBytes = view.getUint32(6, true);
      const totalPixels = width * height;
      const palette: [number, number, number][] = [];
      let offset = 10;
      
      for (let index = 0; index < paletteBytes; index += 3) {
        palette.push([
          bytes[offset + index],
          bytes[offset + index + 1],
          bytes[offset + index + 2],
        ]);
      }

      offset += paletteBytes;
      const frameEnd = offset + frameBytes;
      const frames: Uint8Array[] = [];
      let current: Uint8Array | null = null;
      
      function readU16BE(bytes: Uint8Array, offset: number) {
        return (bytes[offset] << 8) | bytes[offset + 1];
      }

      while (offset < frameEnd) {
        const record = bytes[offset];
        offset += 1;
        
        if (record === 0x49) {
          const pixelCount = readU16BE(bytes, offset);
          offset += 2;
          current = new Uint8Array(totalPixels);
          current.set(bytes.subarray(offset, offset + pixelCount), 0);
          offset += pixelCount;
          frames.push(current.slice());
        } else if (record === 0x50) {
          if (!current) {
            throw new Error("predictive frame before keyframe");
          }
          const changedPixels = readU16BE(bytes, offset);
          offset += 2;
          const positionBytes = totalPixels > 256 ? 2 : 1;
          const next: Uint8Array = current.slice();
          for (let index = 0; index < changedPixels; index += 1) {
            const position = positionBytes === 2 ? readU16BE(bytes, offset) : bytes[offset];
            offset += positionBytes;
            next[position] = bytes[offset];
            offset += 1;
          }
          current = next;
          frames.push(next.slice());
        }
      }

      return { frames, palette, fps };
    }

    function drawFrame(
      ctx: CanvasRenderingContext2D,
      decoded: any,
      frameIndex: number
    ) {
      const frame = decoded.frames[frameIndex];
      const palette = decoded.palette;
      const imageData = ctx.createImageData(ctx.canvas.width, ctx.canvas.height);
      const data = imageData.data;

      for (let i = 0; i < frame.length; i++) {
        const paletteIndex = frame[i];
        const [r, g, b] = palette[paletteIndex];
        data[i * 4] = r;
        data[i * 4 + 1] = g;
        data[i * 4 + 2] = b;
        data[i * 4 + 3] = 255;
      }

      ctx.putImageData(imageData, 0, 0);
    }

    async function renderAnimationPreview(
      animationPath: string,
      canvas: HTMLCanvasElement,
      status: HTMLElement
    ) {
      try {
        const response = await fetch(animationPath);
        if (!response.ok) {
          throw new Error(`HTTP ${response.status}`);
        }

        const decoded = decodeAnimationBinary(
          new Uint8Array(await response.arrayBuffer()),
          canvas.width,
          canvas.height
        );
        
        const context = canvas.getContext("2d");
        if (!context) throw new Error("Could not get canvas context");
        
        const delay = Math.max(20, Math.round(1000 / Math.max(1, decoded.fps)));
        let frame = 0;
        drawFrame(context, decoded, frame);
        status.textContent = "";
        status.hidden = true;

        if (decoded.frames.length > 1) {
          setInterval(() => {
            frame = (frame + 1) % decoded.frames.length;
            drawFrame(context, decoded, frame);
          }, delay);
        }
      } catch (error) {
        status.hidden = false;
        status.textContent = `Preview unavailable: ${error instanceof Error ? error.message : String(error)}`;
      }
    }

    // Initialize all animation previews
    document.querySelectorAll("[data-animation-preview]").forEach((canvas) => {
      const canvasEl = canvas as HTMLCanvasElement;
      const animationPath = canvasEl.getAttribute("data-animation-preview");
      const statusEl = canvasEl.closest(".animation-card")?.querySelector(".status");
      
      if (animationPath && statusEl instanceof HTMLElement) {
        renderAnimationPreview(animationPath, canvasEl, statusEl);
      }
    });

    document.querySelectorAll("[data-manifest-open]").forEach((trigger) => {
      trigger.addEventListener("click", () => {
        const dialogId = (trigger as HTMLElement).dataset.manifestOpen;
        const dialog = dialogId ? document.getElementById(dialogId) : null;

        if (dialog instanceof HTMLDialogElement) {
          dialog.showModal();
        }
      });
    });

    document.querySelectorAll(".manifest-dialog").forEach((dialog) => {
      if (!(dialog instanceof HTMLDialogElement)) return;

      dialog.querySelector("[data-manifest-close]")?.addEventListener("click", () => {
        dialog.close();
      });

      dialog.addEventListener("click", (event) => {
        if (event.target === dialog) {
          dialog.close();
        }
      });
    });
  </script>
</Layout>
