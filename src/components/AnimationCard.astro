---
interface Props {
  animation: {
    name: string;
    publishedName: string;
    dimensions: string;
    width: number;
    height: number;
    frames: number;
    fps: number;
    paletteColors: number;
    bytes: number;
    path: string;
    deployedIndex: number;
  };
  galleryOrder: number;
  displayState: string;
}

const { animation, galleryOrder, displayState } = Astro.props;
const githubUrl = `https://github.com/JakeShirley/pixel-content/blob/main/assets/processed/${encodeURIComponent(animation.dimensions)}/${encodeURIComponent(animation.name)}.bin`;
const basePath = `${import.meta.env.BASE_URL.replace(/\/$/, '')}/`;

function formatBytes(bytes: number) {
  if (bytes < 1024) return `${bytes} B`;

  const units = ['KB', 'MB', 'GB'];
  const unitIndex = Math.min(Math.floor(Math.log(bytes) / Math.log(1024)) - 1, units.length - 1);
  const value = bytes / 1024 ** (unitIndex + 1);

  return `${value.toLocaleString(undefined, { maximumFractionDigits: 1 })} ${units[unitIndex]}`;
}
---

<li
  data-animation-dimensions={animation.dimensions}
  data-deployed-index={animation.deployedIndex}
  data-gallery-order={galleryOrder}
  data-display-state={displayState}
  style={`--preview-aspect: ${animation.width} / ${animation.height}`}
>
  <article class="animation-card">
    <div class="preview">
      <canvas
        width={animation.width}
        height={animation.height}
        aria-label={`${animation.name} preview`}
        data-animation-preview={animation.path}
      ></canvas>
    </div>
    <div class="details">
      <h3>
        <a href={githubUrl}>{animation.name}</a>
      </h3>
      <div class="links">
        <a href={`${basePath}converter/?file=../${animation.path}`}>Open in Animation Editor</a>
      </div>
      <div class="meta">
        <span>{animation.frames} frames</span>
        <span>{animation.fps} fps</span>
        <span>{animation.paletteColors} colors</span>
        <span>{formatBytes(animation.bytes)}</span>
      </div>
      <p class="status">Loading preview...</p>
    </div>
  </article>
</li>

<style>
  li {
    position: relative;
    min-width: 0;
  }

  .animation-card {
    display: grid;
    break-inside: avoid;
    margin-bottom: 6px;
    background: var(--panel);
    list-style: none;
  }

  .preview {
    display: grid;
    place-items: center;
    aspect-ratio: var(--preview-aspect);
    min-height: 0;
    overflow: hidden;
    background: #171717;
  }

  canvas {
    width: 100%;
    height: 100%;
    object-fit: contain;
    background: #171717;
    image-rendering: pixelated;
  }

  .details {
    display: grid;
    align-content: start;
    gap: 7px;
    min-width: 0;
    padding: 12px 12px 14px;
  }

  .details h3 {
    overflow-wrap: anywhere;
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.2;
    margin: 0;
  }

  .links {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    font: 0.7rem/1.2 var(--font-ui);
  }

  .links a {
    color: var(--accent-strong);
    font-weight: 400;
    text-decoration: none;
  }

  .links a:hover {
    text-decoration: underline;
  }

  .meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .meta span {
    border: 0;
    background: transparent;
    padding: 0;
    color: var(--muted);
    font: 0.65rem/1.3 var(--font-ui);
  }

  .status {
    color: var(--muted);
    font: 0.68rem/1.3 var(--font-ui);
    margin: 0;
  }

  @media (max-width: 560px) {
    .details {
      padding: 9px 9px 12px;
    }

    .details h3 {
      font-size: 0.9rem;
    }

    .meta span:nth-child(3),
    .meta span:nth-child(4) {
      display: none;
    }
  }
</style>
